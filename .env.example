# GitHub OAuth App client ID. Same one as the PWA — the extension can share an OAuth App.
# Get it from https://github.com/settings/developers (enable Device Flow on the app).
VITE_GITHUB_CLIENT_ID=Ov23xxxxxxxxxxxxxxx

# Optional: Cloudflare Worker URL that proxies github.com/login/* with CORS headers.
# Use the SAME proxy URL as the app — sign-in works without CORS workarounds.
# See lazylingo-app/worker/README.md for deploy steps.
VITE_GITHUB_AUTH_PROXY=
